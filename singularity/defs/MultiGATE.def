Bootstrap: docker
From: nvidia/cuda:11.8.0-cudnn8-runtime-ubuntu22.04

%labels
    Method MultiGATE
    Description MultiGATE requires TensorFlow 1.15 - separate base image

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        python3.8 python3.8-dev python3.8-venv python3-pip \
        git wget build-essential \
        r-base r-base-dev \
        libhdf5-dev libffi-dev libssl-dev \
        && rm -rf /var/lib/apt/lists/*

    update-alternatives --install /usr/bin/python python /usr/bin/python3.8 1
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.8 1
    python -m pip install --upgrade pip setuptools wheel

    # MultiGATE uses TensorFlow 1.15 (incompatible with PyTorch base)
    pip install \
        tensorflow-gpu==1.15.0 \
        numpy==1.21.6 \
        pandas==1.3.5 \
        scipy==1.7.3 \
        scikit-learn==1.0.2 \
        scanpy==1.9.3 \
        anndata==0.9.2 \
        matplotlib==3.5.3 \
        seaborn==0.12.2 \
        networkx==2.6 \
        pybedtools==0.9.0 \
        gseapy==1.0.4 \
        rpy2==3.5.16 \
        louvain==0.8.0 \
        leidenalg \
        tqdm \
        h5py \
        pynvml

    R -e "install.packages('mclust', repos='https://cloud.r-project.org/')"
    mkdir -p /app

%environment
    export LC_ALL=C
    export METHOD_NAME=MultiGATE
    export PYTHONNOUSERSITE=1
